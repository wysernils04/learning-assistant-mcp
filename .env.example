# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Required ──────────────────────────────────────────────────────────────────

# Absolute path to the root of your Obsidian vault.
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Subfolder inside the vault where learning notes live.
OBSIDIAN_LERNEN_DIR=📚 Lernen

# Path to the SQLite index/cache. Defaults to <vault>/.learning_index.db
# LEARNING_DB_PATH=/path/to/custom/learning_index.db

# SBB OpenData API base URL (public, no key required).
SBB_API_BASE=https://transport.opendata.ch/v1

# Fallback travel buffer in minutes when SBB API is unavailable.
SBB_TRAVEL_FALLBACK_MIN=30

# ── Future: Google Calendar ────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
